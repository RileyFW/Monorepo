[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]

gunicorn = "==20.1.0" # Was specifically versioned by the last team. TODO see if we can update it.
numpy = "*"
configparser = "*"
python-magic = "*"
python-dotenv = "*"
matplotlib = "*"
pymongo = "*"
pydantic = "==1.10.7"
pytest-cov = "*"
pipreqs = "*"
# Gmail sending moved to the backend, so the runner no longer needs the Google
# client libraries (removes them from the untrusted runner image).
websockets = "*"
pyyaml = "*"

[dev-packages]
python-magic-bin = {markers = "platform_system == 'Windows'"}
yapf = "*"
pylint = "*"
pytest = "*"
coverage = "*"

[requires]
python_version = "3.9"
